<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cadastro de Livros</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <nav class="navbar">
        <div class="nav-container">
            <a href="#" class="nav-link">Catálogo</a>
            <a href="#" class="nav-link active">Novo</a>
        </div>
    </nav>

    <main class="form-container">
        <h1 class="form-title">Dados do Livro</h1>
        
        <form action="#" method="POST">
            
            <div class="form-group">
                <label for="titulo">Título</label>
                <input type="text" id="titulo" name="titulo" required autofocus>
            </div>

            <div class="form-group">
                <label for="resumo">Resumo</label>
                <textarea id="resumo" name="resumo" rows="4" required></textarea>
            </div>

            <div class="form-group">
                <label for="editora">Editora</label>
                <select id="editora" name="editora" required>
                    <option value="addison-wesley" selected>Addison Wesley</option>
                    <option value="oreilly">O'Reilly</option>
                    <option value="casa-do-codigo">Casa do Código</option>
                </select>
            </div>

            <div class="form-group">
                <label for="autores">Autores (1 por linha)</label>
                <textarea id="autores" name="autores" rows="4" required></textarea>
            </div>

            <button type="submit" class="btn-submit">Salvar Dados</button>

        </form>
    </main>

</body>
</html>
