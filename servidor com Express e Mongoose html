<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MongoDB Compass Clone</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <div class="dashboard-mock">
        <button id="btnOpenModal" class="btn-primary">Create database</button>
    </div>

    <div id="modalOverlay" class="modal-overlay active">
        <div class="modal-card">
            
            <button id="btnCloseX" class="modal-close-x">&times;</button>
            
            <h2 class="modal-title">Create Database</h2>
            
            <form id="createDatabaseForm">
                <div class="form-group">
                    <label for="databaseName">Database Name</label>
                    <input type="text" id="databaseName" value="livraria" required>
                </div>

                <div class="form-group">
                    <label for="collectionName">Collection Name</label>
                    <input type="text" id="collectionName" value="livros" class="input-focus-blue" required>
                </div>

                <div class="advanced-options">
                    <span class="arrow">&#x276F;</span>
                    <span class="advanced-text">
                        <strong>Advanced Collection Options</strong> (e.g. Time-Series, Capped, Clustered collections)
                    </span>
                </div>

                <div class="modal-footer">
                    <button type="button" id="btnCancel" class="btn-secondary">Cancel</button>
                    <button type="submit" class="btn-success">Create Database</button>
                </div>
            </form>

        </div>
    </div>

    <script src="script.js"></script>
</body>
</html>
